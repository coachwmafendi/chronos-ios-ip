{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Chronos",
  "version": "0.1.0",
  "identifier": "com.wmafendi.chronos",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Chronos",
        "width": 800,
        "height": 600,
        "minWidth": 480,
        "minHeight": 720,
        "backgroundColor": "#1a1a1a"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
"shortDescription": "A simple time companion.",
    "longDescription": "Chronos brings essential time tools into a clean and focused experience.\n\nDesigned and developed by Wan Mohd Afendi using Rust and Tauri.",
    "copyright": "© 2026 Wan Mohd Afendi. All rights reserved.",
    "macOS": {
      "minimumSystemVersion": "13.0"
    }
  }
}
